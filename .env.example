# ---- Core runtime mode ----
BOT_ENABLED=true
LIVE_TRADING=false
I_UNDERSTAND_REAL_MONEY=false

# Path to the bot config. Leave unset to auto-discover from the repo root.
# BOT_CONFIG_PATH=/absolute/path/to/config/bot.json

# ---- Postgres ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tradingbot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Frontend (read by Next.js at build/runtime) ----
NEXT_PUBLIC_MARKET_API=http://localhost:8001
NEXT_PUBLIC_TRADING_API=http://localhost:8002
NEXT_PUBLIC_STRATEGY_API=http://localhost:8003
